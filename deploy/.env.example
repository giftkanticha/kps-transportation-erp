# Copy to .env (same folder) and change the secrets before deploying.
# docker compose reads this file automatically.

# Database
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=kps_erp
MYSQL_USER=kps
MYSQL_PASSWORD=change-this-db-password

# JWT secrets — MUST change to long random strings in production
JWT_SECRET=change-this-to-a-long-random-string
REFRESH_TOKEN_SECRET=change-this-to-another-long-random-string

# Port the app is served on (browser opens http://<server-ip>:APP_PORT)
APP_PORT=3001

# Public URL the app is reached at — used in password-reset email links.
# Set to the address users actually open (LAN IP or your domain).
APP_BASE_URL=http://192.168.1.50:3001

# SMTP for password-reset emails (optional). Leave SMTP_HOST empty to disable
# email — reset still works, the link is shown to the admin/user on screen.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=KPS ERP <no-reply@kps.local>

# ── Automated backups ────────────────────────────────────────────────────────
# Where dump files are written. Default ./backups (next to this file). Point at
# a cloud-synced folder for an off-site copy, e.g. on Windows:
#   BACKUP_DIR=C:/Users/YOU/OneDrive/kps-backups
BACKUP_DIR=./backups
BACKUP_KEEP_DAYS=14
BACKUP_INTERVAL=86400          # seconds between backups (86400 = once a day)

# ── Remote access via Cloudflare Tunnel (optional) ───────────────────────────
# Paste the tunnel token from Cloudflare Zero Trust → Networks → Tunnels, then
# run: docker compose --profile tunnel up -d   (see deploy/README.md)
TUNNEL_TOKEN=

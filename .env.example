# Which data backend the build talks to: 'supabase' (default, cloud — original
# behaviour) or 'mysql' (self-hosted REST API in server/). See deploy/README.md.
# VITE_DATA_BACKEND=mysql
# Base URL of the API in MySQL mode. Empty = same-origin (recommended).
# For `npm run dev:all` use: VITE_API_URL=http://localhost:3001

# Supabase mode only:
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

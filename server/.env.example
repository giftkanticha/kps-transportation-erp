# SQLite (default, original auth dev):
DATABASE_URL="file:./dev.db"
# MySQL (self-hosted deployment) — use this instead and run the *:mysql scripts:
# DATABASE_URL="mysql://kps:password@localhost:3306/kps_erp"

# One-time data migration from Supabase (optional):
#   SUPABASE_URL / SUPABASE_SERVICE_KEY  -> operational tables (npm run migrate:supabase)
#   SUPABASE_DB_URL (direct Postgres URI) -> users + password hashes (npm run migrate:users)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
# SUPABASE_DB_URL=postgresql://postgres:[DB-PASSWORD]@db.xxxx.supabase.co:5432/postgres
JWT_SECRET="change-this-to-a-random-secret"
REFRESH_TOKEN_SECRET="change-this-to-a-different-random-secret"
PORT=3001

# Optional: lock CORS to specific origins (comma-separated). Default reflects
# any LAN origin (safe — auth is Bearer-token, not cookies).
# CORS_ORIGIN=http://192.168.1.50:3001

# Public URL the app is reached at — used to build password-reset links in emails.
# APP_BASE_URL=http://192.168.1.50:3001

# SMTP for password-reset emails. If SMTP_HOST is empty, reset still works but the
# link is returned to the admin/user on screen instead of being emailed.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false        # true for port 465 (implicit TLS)
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="KPS ERP <you@gmail.com>"

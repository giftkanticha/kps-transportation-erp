  status             String   @default("scheduled")
  progress           Int      @default(0)
  startOdometer      Decimal? @map("start_odometer") @db.Decimal(18, 2)
  endOdometer        Decimal? @map("end_odometer") @db.Decimal(18, 2)
  distance           Decimal? @db.Decimal(18, 2)
  liters             Decimal? @db.Decimal(18, 2)
  kmPerL             Decimal? @map("km_per_l") @db.Decimal(18, 2)
  perDiem            Decimal? @map("per_diem") @db.Decimal(18, 2)
  notes              String   @default("") @db.VarChar(1000)
  totalAmount        Decimal  @default(0) @map("total_amount") @db.Decimal(18, 2)
  revenue            Decimal  @default(0) @db.Decimal(18, 2)

  accountingPeriodId String?  @map("accounting_period_id") @db.VarChar(36)
  carryForwardFrom   String?  @map("carry_forward_from") @db.VarChar(36)
  splitParentId      String?  @map("split_parent_id") @db.VarChar(36)
  locked             Boolean  @default(false)
  paymentStatus      String   @default("unpaid") @map("payment_status")
  amountPaid         Decimal  @default(0) @map("amount_paid") @db.Decimal(18, 2)
  paidAt             String?  @map("paid_at")
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([accountingPeriodId])
  @@index([locked])
  @@index([paymentStatus])
  @@map("dispatch")
}


  reviewerId    String?   @map("reviewer_id") @db.VarChar(36)
  reviewerName  String?   @map("reviewer_name")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewNote    String?   @map("review_note") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([periodId])
  @@index([status])
  @@map("period_unlock_requests")
}

model CompanySetting {
  id        Int      @id @default(1)
  name      String   @default("")
  taxId     String   @default("") @map("tax_id")
  phone     String   @default("")
  email     String   @default("")
  address   String   @default("") @db.VarChar(1000)
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.VarChar(36)

  @@map("company_settings")
}

model CompanyBankAccount {
  id          String   @id @default(uuid()) @db.VarChar(36)
  bankName    String   @map("bank_name")
  accountNo   String   @map("account_no")
  accountName String   @map("account_name")
  branch      String   @default("")
  isDefault   Boolean  @default(false) @map("is_default")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("company_bank_accounts")
}

model BillingNote {
  id               String   @id @default(uuid()) @db.VarChar(36)
  code             String   @unique
  docType          String   @default("billing_note") @map("doc_type")
  customerId       String?  @map("customer_id") @db.VarChar(36)
  customerName     String   @default("") @map("customer_name")
  year             Int
  month            Int
  bankAccountId    String?  @map("bank_account_id") @db.VarChar(36)
  gross            Decimal  @default(0) @db.Decimal(18, 2)
  whtAmount        Decimal  @default(0) @map("wht_amount") @db.Decimal(18, 2)
  net              Decimal  @default(0) @db.Decimal(18, 2)
  dispatchIds      Json?    @map("dispatch_ids") @db.Json
  status           String   @default("issued")
  issuedAt         DateTime @default(now()) @map("issued_at")
  paidAt           String?  @map("paid_at")
  notes            String   @default("") @db.VarChar(1000)
  createdAt        DateTime @default(now()) @map("created_at")
  legIds           Json     @map("leg_ids") @db.Json
  billToLocationId String?  @map("bill_to_location_id") @db.VarChar(36)

  @@index([customerId])
  @@index([year, month])
  @@map("billing_notes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Supabase-auth view tables (referenced by name from admin pages).
// In Postgres these PKs referenced auth.users(id); here they are plain UUIDs.
// ─────────────────────────────────────────────────────────────────────────────

model UserProfile {
  id          String    @id @db.VarChar(36)
  displayName String    @default("") @map("display_name")
  phone       String    @default("")
  role        String    @default("EMPLOYEE")
  status      String    @default("PENDING_APPROVAL")
  approvedBy  String?   @map("approved_by") @db.VarChar(36)
  approvedAt  DateTime? @map("approved_at")
  employeeId  String?   @map("employee_id") @db.VarChar(36)
  email       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([role])
  @@index([status])
  @@index([employeeId])
  @@map("user_profiles")
}

model UserPermission {
  id          String   @id @default(uuid()) @db.VarChar(36)
  userId      String   @map("user_id") @db.VarChar(36)
  category    String
  actionLevel String   @map("action_level")
  grantedBy   String?  @map("granted_by") @db.VarChar(36)
  remark      String?  @db.Text
  grantedAt   DateTime @default(now()) @map("granted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, category, actionLevel])
  @@map("user_permissions")
}

model AclAuditLog {
  id          String   @id @default(uuid()) @db.VarChar(36)
  actorId     String?  @map("actor_id") @db.VarChar(36)
  targetId    String?  @map("target_id") @db.VarChar(36)
  action      String
  category    String?
  actionLevel String?  @map("action_level")
  oldValue    String?  @map("old_value") @db.Text
  newValue    String?  @map("new_value") @db.Text
  details     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("acl_audit_log")
}

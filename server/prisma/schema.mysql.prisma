// KPS Transportation ERP — MySQL Prisma schema.
// Translated from the PostgreSQL Supabase migrations
// (supabase/migrations/0001..0040). The 6 AUTH models at the top are copied
// verbatim from schema.prisma (provider-agnostic, no changes for MySQL).
//
// DESIGN NOTE on relations: all foreign-key columns from the operational
// tables are kept as PLAIN String fields WITHOUT Prisma `@relation` wiring.
// The application performs its own joins (it was written against Supabase's
// client, not Prisma's relation loader), and several tables have ambiguous /
// circular references (employees.vehicle_id <-> vehicles.driver_id,
// dispatch.split_parent_id self-ref, etc.). Per the task guidance we prefer
// preserving the raw FK columns over guessing relation wiring. The FK columns
// are typed `String? @db.VarChar(36)` to match the UUID PKs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH models (copied verbatim from schema.prisma — provider-agnostic)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  username         String    @unique
  email            String?   @unique
  displayName      String
  phone            String?
  passwordHash     String
  status           String    @default("PENDING_APPROVAL")
  role             String    @default("EMPLOYEE")
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  approvedBy       String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  loginHistories    LoginHistory[]
  passwordResets    PasswordReset[]
  customPermissions RolePermission[]
  auditLogs         AuditLog[]
}

model LoginHistory {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress     String?
  success       Boolean
  failureReason String?
  loginAt       DateTime @default(now())
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model RolePermission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    String
  actionLevel String
  grantedBy   String?
  remark      String?
  isOverride  Boolean  @default(false)
  grantedAt   DateTime @default(now())

  @@unique([userId, category, actionLevel])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  category    String?
  actionLevel String?
  oldValue    String?
  newValue    String?
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model DataResetLog {
  id          String    @id @default(cuid())
  resetBy     String
  resetType   String    @default("MANUAL")
  details     String?
  status      String
  errorMsg    String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

// ─────────────────────────────────────────────────────────────────────────────
// Operational tables (translated from Supabase migrations)
// ─────────────────────────────────────────────────────────────────────────────

model Vehicle {

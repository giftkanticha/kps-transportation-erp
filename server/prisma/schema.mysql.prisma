  status         String   @default("available")
  driverId       String?  @map("driver_id") @db.VarChar(36)
  odometer       Decimal  @default(0) @db.Decimal(18, 2)
  nextServiceKm  Decimal  @default(0) @map("next_service_km") @db.Decimal(18, 2)
  fuel           Decimal  @default(0) @db.Decimal(18, 2)
  lastService    String   @default("") @map("last_service")
  nextService    String   @default("") @map("next_service")
  purchaseDate   String   @default("") @map("purchase_date")
  tax            String   @default("")
  insurance      String   @default("")
  dispatchPermit String   @default("") @map("dispatch_permit")
  groupKind      String?  @map("group_kind")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("vehicles")
}


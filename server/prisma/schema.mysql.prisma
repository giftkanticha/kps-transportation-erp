  reviewNote    String    @default("") @map("review_note") @db.VarChar(1000)
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("edit_approvals")
}

model VehicleRegistration {
  id        String   @id @default(uuid()) @db.VarChar(36)
  data      Json     @db.Json
  createdAt DateTime @default(now()) @map("created_at")

  @@map("vehicle_registrations")
}

model RequestApproval {
  id        String   @id @default(uuid()) @db.VarChar(36)
  data      Json     @db.Json
  createdAt DateTime @default(now()) @map("created_at")

  @@map("request_approvals")
}

model Location {
  id         String   @id @default(uuid()) @db.VarChar(36)
  name       String   @unique
  category   String   @default("")
  province   String   @default("")
  address    String   @default("") @db.VarChar(1000)
  notes      String   @default("") @db.VarChar(1000)
  active     Boolean  @default(true)
  isCustomer Boolean  @default(false) @map("is_customer")
  credit     Int      @default(30)
  taxId      String   @default("") @map("tax_id")
  phone      String   @default("")
  contact    String   @default("")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("locations")
}

model AccountingPeriod {
  id           String    @id @default(uuid()) @db.VarChar(36)
  year         Int
  month        Int
  status       String    @default("OPEN")
  closedAt     DateTime? @map("closed_at")
  closedBy     String?   @map("closed_by") @db.VarChar(36)
  closedByName String?   @map("closed_by_name")
  reopenedAt   DateTime? @map("reopened_at")
  reopenedBy   String?   @map("reopened_by") @db.VarChar(36)
  reopenReason String?   @map("reopen_reason") @db.Text
  notes        String    @default("") @db.VarChar(1000)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([year, month])
  @@index([year, month])
  @@index([status])
  @@map("accounting_periods")
}

model AccountingPeriodSnapshot {
  id        String   @id @default(uuid()) @db.VarChar(36)
  periodId  String   @map("period_id") @db.VarChar(36)
  vehicleId String?  @map("vehicle_id") @db.VarChar(36)
  plate     String
  data      Json     @db.Json
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([periodId, vehicleId])
  @@index([periodId])
  @@map("accounting_period_snapshots")
}

model PeriodUnlockRequest {
  id            String    @id @default(uuid()) @db.VarChar(36)
  periodId      String    @map("period_id") @db.VarChar(36)
  requesterId   String?   @map("requester_id") @db.VarChar(36)
  requesterName String    @default("") @map("requester_name")
  reason        String    @db.Text
